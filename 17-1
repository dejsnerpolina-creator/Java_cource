import java.util.ArrayList;
import java.util.List;

public class Practice1 {
    
    // Параметризованный класс
    static class Box<T> {
        private T item;
        
        public void setItem(T item) {
            this.item = item;
        }
        
        public T getItem() {
            return item;
        }
    }
    
    public static void main(String[] args) {
        
        System.out.println("=== instanceof с параметризованными классами ===\n");
        
        // Создаем объекты разных типов
        Box<String> stringBox = new Box<>();
        Box<Integer> integerBox = new Box<>();
        Box<Double> doubleBox = new Box<>();
        
        // 1. Проверка на сырой тип (raw type)
        System.out.println("--- Проверка на сырой тип ---");
        System.out.println("stringBox instanceof Box: " + (stringBox instanceof Box));
        System.out.println("integerBox instanceof Box: " + (integerBox instanceof Box));
        // Оба true, так как при проверке instanceof тип параметра стирается
        
        // 2. Проверка на сырой тип с wildcard
        System.out.println("\n--- Проверка с wildcard ---");
        System.out.println("stringBox instanceof Box<?>: " + (stringBox instanceof Box<?>));
        System.out.println("integerBox instanceof Box<?>: " + (integerBox instanceof Box<?>));
        
        // 3. Практический пример: безопасное приведение типов
        System.out.println("\n--- Безопасное приведение типов ---");
        
        Object obj = stringBox;
        
        if (obj instanceof Box) {
            Box<?> box = (Box<?>) obj;
            Object item = box.getItem();
            System.out.println("Объект является Box, содержимое: " + item);
        }
        
        // 4. Пример с List
        System.out.println("\n--- Пример с List ---");
        List<String> stringList = new ArrayList<>();
        List<Integer> integerList = new ArrayList<>();
        
        System.out.println("stringList instanceof List: " + (stringList instanceof List));
        System.out.println("integerList instanceof List: " + (integerList instanceof List));
        // System.out.println(stringList instanceof List<String>); 
        }
    }
}
