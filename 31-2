import java.util.StringJoiner;

public class StringJoinerDemo {
    public static void main(String[] args) {
        
        System.out.println("=== StringJoiner с разделителем ===");
        // Создаём StringJoiner с разделителем ", "
        StringJoiner joiner1 = new StringJoiner(", ");
        joiner1.add("Яблоко");
        joiner1.add("Груша");
        joiner1.add("Апельсин");
        System.out.println(joiner1); // Яблоко, Груша, Апельсин
        
        System.out.println("\n=== StringJoiner с префиксом и суффиксом ===");
        // Создаём StringJoiner с разделителем ", ", префиксом "[" и суффиксом "]"
        StringJoiner joiner2 = new StringJoiner(", ", "[", "]");
        joiner2.add("Красный");
        joiner2.add("Синий");
        joiner2.add("Зелёный");
        System.out.println(joiner2); // [Красный, Синий, Зелёный]
        
        System.out.println("\n=== Объединение двух StringJoiner ===");
        StringJoiner joiner3 = new StringJoiner(", ");
        joiner3.add("Один");
        joiner3.add("Два");
        
        StringJoiner joiner4 = new StringJoiner(", ");
        joiner4.add("Три");
        joiner4.add("Четыре");
        
        joiner3.merge(joiner4);
        System.out.println(joiner3); // Один, Два, Три, Четыре
        
        System.out.println("\n=== setEmptyValue() - значение для пустого Joiner ===");
        StringJoiner emptyJoiner = new StringJoiner(", ", "[", "]");
        emptyJoiner.setEmptyValue("Пусто");
        System.out.println("Пустой: " + emptyJoiner); // Пусто
        
        emptyJoiner.add("Элемент");
        System.out.println("Не пустой: " + emptyJoiner); // [Элемент]
        
        System.out.println("\n=== Реальный пример: формирование SQL запроса ===");
        StringJoiner columns = new StringJoiner(", ");
        columns.add("id").add("name").add("age");
        
        StringJoiner values = new StringJoiner(", ", "(", ")");
        values.add("1").add("'Иван'").add("25");
        
        System.out.println("INSERT INTO users (" + columns + ") VALUES " + values);
        // INSERT INTO users (id, name, age) VALUES (1, 'Иван', 25)
        
        System.out.println("\n=== Альтернатива: String.join() ===");
        // Для простых случаев можно использовать String.join()
        String simple = String.join(" | ", "A", "B", "C");
        System.out.println(simple); // A | B | C
    }
}
