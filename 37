class MyException extends Exception {
    public MyException() {
        super("Что-то пошло не так!");
    }
}

public class Main {
    public static void main(String[] args) {
        
        try {
            throw new MyException();
        } catch (MyException e) {
            System.out.println("Поймали исключение: " + e.getMessage());
        }
    }
}
