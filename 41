import java.io.File;
import java.io.FileNotFoundException;
import java.util.Scanner;

public class ScannerFileDemo {
    public static void main(String[] args) {
        
        // Способ 1: Чтение всего файла построчно
        System.out.println("=== Чтение построчно ===");
        try {
            File file = new File("input.txt");
            Scanner scanner = new Scanner(file);
            
            while (scanner.hasNextLine()) {
                String line = scanner.nextLine();
                System.out.println(line);
            }
            scanner.close();
            
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден: " + e.getMessage());
        }
        
        // Способ 2: Чтение по словам
        System.out.println("\n=== Чтение по словам ===");
        try {
            Scanner scanner = new Scanner(new File("input.txt"));
            
            while (scanner.hasNext()) {
                String word = scanner.next();
                System.out.println("Слово: " + word);
            }
            scanner.close();
            
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден");
        }
        
        // Способ 3: Чтение чисел из файла
        System.out.println("\n=== Чтение чисел ===");
        try {
            Scanner scanner = new Scanner(new File("numbers.txt"));
            
            int sum = 0;
            while (scanner.hasNextInt()) {
                int number = scanner.nextInt();
                sum += number;
                System.out.println("Число: " + number);
            }
            System.out.println("Сумма: " + sum);
            scanner.close();
            
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден");
        }
        
        // Способ 4: Чтение с разделителем (CSV)
        System.out.println("\n=== Чтение CSV с разделителем запятая ===");
        try {
            Scanner scanner = new Scanner(new File("data.csv"));
            scanner.useDelimiter(",");
            
            while (scanner.hasNext()) {
                String token = scanner.next();
                System.out.println("Token: " + token.trim());
            }
            scanner.close();
            
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден");
        }
        
        // Способ 5: try-with-resources (автоматическое закрытие)
        System.out.println("\n=== try-with-resources ===");
        try (Scanner scanner = new Scanner(new File("input.txt"))) {
            while (scanner.hasNextLine()) {
                System.out.println(scanner.nextLine());
            }
        } catch (FileNotFoundException e) {
            System.out.println("Файл не найден");
        }
    }
}
